{
  "$comment": "painel-ins design tokens. Cores em HSL 'H S% L%' (compor com alpha). Fonte da verdade espelhada de tokens.css.",
  "color": {
    "surface": {
      "background": "220 20% 4%",
      "foreground": "150 100% 90%",
      "card": "220 20% 7%",
      "card-foreground": "150 80% 90%",
      "popover": "220 20% 6%",
      "popover-foreground": "150 80% 90%"
    },
    "brand": {
      "primary": "150 100% 45%",
      "primary-foreground": "220 20% 4%",
      "secondary": "260 100% 65%",
      "secondary-foreground": "0 0% 98%",
      "accent": "150 60% 40%",
      "accent-foreground": "220 20% 4%",
      "destructive": "0 85% 55%",
      "destructive-foreground": "0 0% 98%"
    },
    "util": {
      "muted": "220 15% 12%",
      "muted-foreground": "150 20% 55%",
      "border": "150 40% 12%",
      "input": "220 15% 14%",
      "ring": "150 100% 45%"
    },
    "chart": {
      "1": "150 100% 45%",
      "2": "190 100% 50%",
      "3": "260 100% 65%",
      "4": "45 100% 55%",
      "5": "0 85% 55%"
    },
    "sidebar": {
      "background": "220 20% 5%",
      "foreground": "150 60% 70%",
      "primary": "150 100% 45%",
      "primary-foreground": "220 20% 4%",
      "accent": "220 15% 10%",
      "accent-foreground": "150 80% 80%",
      "border": "150 40% 12%",
      "ring": "150 100% 45%"
    },
    "neon": {
      "orange": { "hsl": "28 100% 55%", "hex": "#ff8c1a" },
      "green":  { "hsl": "152 100% 45%", "hex": "#00e676" },
      "blue":   { "hsl": "187 100% 42%", "hex": "#00bcd4" },
      "purple": { "hsl": "255 100% 76%", "hex": "#b388ff" },
      "red":    { "hsl": "0 100% 66%", "hex": "#ff5252" },
      "yellow": { "hsl": "47 100% 62%", "hex": "#ffd740" }
    }
  },
  "radius": "0.5rem",
  "font": {
    "display": "Orbitron, ui-sans-serif, system-ui, sans-serif",
    "heading": "Orbitron, ui-sans-serif, system-ui, sans-serif",
    "body": "Inter, ui-sans-serif, system-ui, sans-serif",
    "mono": "JetBrains Mono, ui-monospace, SFMono-Regular, Menlo, Consolas, monospace"
  },
  "motion": {
    "duration": { "fast": "0.2s", "base": "0.3s", "page": "0.4s", "slow": "0.5s" },
    "easing": { "out": "easeOut", "inOut": "easeInOut" },
    "stagger": "index * 0.1s"
  }
}
